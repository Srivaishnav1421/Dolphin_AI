# ══════════════════════════════════════════════════════════════
#  Chubby Dolphin AI — Environment Variables
#  Copy this to .env and fill in your real values
#  NEVER commit .env to git!
# ══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=chubbydb
POSTGRES_USER=chubby
POSTGRES_PASSWORD=dolphin123

# ── Spring Profile ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Gemini AI (Cloud Fallback) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Ollama (Local LLM — Primary) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-v0.3-q4_K_M
OLLAMA_ENABLED=true

# ── Hugging Face (Cloud Fallback #2) ─────────────────────────
HF_TOKEN=your_huggingface_token_here

# ── Meta Marketing API ───────────────────────────────────────
# Get these from: https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:4200/meta/callback
META_WEBHOOK_VERIFY_TOKEN=chubby_dolphin_verify_2024

# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=ChubbyDolphinAI_SuperSecretKey_2024_HS256_MinLength32BytesRequired!!

# ── Email Alerts (Gmail App Password) ─────────────────────────
# Create App Password: Google Account → Security → 2FA → App Passwords
MAIL_USER=your_gmail@gmail.com
MAIL_PASS=your_16char_app_password
ALERT_EMAIL=admin@chubby.ai
ALERTS_ENABLED=false

# ── Automated Reports (requires ALERTS_ENABLED=true + mail config) ──
REPORTS_ENABLED=false

# ── Image Generation (DALL-E 3 for ad creatives) ─────────────────────
# Optional — falls back to curated images if not set
OPENAI_API_KEY=your_openai_key_here

# ── Token Encryption (AES-256 for Meta access tokens) ─────────────
# REQUIRED. Must be at least 32 characters. Generate: openssl rand -hex 32
META_ENCRYPTION_KEY=chubby_dolphin_encryption_key_32chars_minimum_required!!

# ── Safety ────────────────────────────────────────────────────
SAFETY_MAX_DAILY_SPEND=50000

# ── Demo Credentials ─────────────────────────────────────────
DEMO_EMAIL=admin@chubby.ai
DEMO_PASSWORD=dolphin123

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200

# ── Docker Hub (for CI/CD) ────────────────────────────────────
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_TOKEN=your_dockerhub_token
