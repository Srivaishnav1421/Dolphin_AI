# DolphinAI production environment template.
# Copy to your secret manager or deployment platform. Do not commit real values.

SPRING_PROFILES_ACTIVE=prod

# Public origins
APP_FRONTEND_URL=https://app.example.com
CORS_ORIGINS=https://app.example.com
META_REDIRECT_URI=https://app.example.com/meta/callback

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/dolphindb
SPRING_DATASOURCE_USERNAME=dolphin
SPRING_DATASOURCE_PASSWORD=replace-with-a-long-random-database-password

# Security secrets
JWT_SECRET=replace-with-at-least-48-random-characters-for-hs256-signing
META_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
META_ENCRYPTION_OLD_KEY=

# Payments
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-live-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret
MANUAL_WALLET_FUNDING_ENABLED=false

# Meta / WhatsApp
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=replace-with-random-webhook-verify-token

# AI providers
HF_TOKEN=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_ENABLED=false

# Redis / queue / automation
REDIS_HOST=redis
REDIS_PORT=6379
RABBITMQ_USER=dolphin
RABBITMQ_PASSWORD=replace-with-long-random-rabbitmq-password
MINIO_ROOT_USER=dolphin
MINIO_ROOT_PASSWORD=replace-with-long-random-minio-password
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-long-random-password
N8N_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-long-random-grafana-password

# Email / alerts
MAIL_USER=
MAIL_PASS=
ALERT_EMAIL=ops@example.com
ALERTS_ENABLED=true

# Corporate billing identity
CORP_STATE_CODE=MH
CORP_LEGAL_NAME=DolphinAI Private Limited
CORP_GSTIN=27AAACC4111D1Z5
CORP_ADDRESS=Replace with registered office address
